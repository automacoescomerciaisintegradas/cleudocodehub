# Cleudocode Core Configuration
# Template: backend
# Focado em desenvolvimento backend (Node.js, Python, Go, etc.)

version: "1.0.0"
name: "cleudocode-core-backend"

settings:
  language: "pt-BR"
  default_agent: "backend-dev"
  verbose: false
  log_mode: "console"

llms:
  models:
    - name: "qwen3:4b"
      backend: "ollama"
      hostname: "http://localhost:11434"
      enabled: true
    - name: "gpt-4o"
      backend: "openai"
      enabled: false

agents:
  enabled:
    - "backend-dev"
    - "api-design"
    - "database"
    - "security"
    - "testing"
  default: "backend-dev"
  max_workers: 8

rules:
  javascript:
    indentation: "space"
    indent_size: 2
    quote_style: "single"
    semicolons: false
  
  python:
    indentation: "space"
    indent_size: 4
    type_hints: true
  
  naming:
    files: "kebab-case"
    functions: "camelCase"
    classes: "PascalCase"
  
  commits:
    style: "conventional"

paths:
  rules: ".agents/rules"
  agents: ".agents/agents"
  templates: ".agents/templates"

features:
  code_generation: true
  auto_documentation: true
  testing: true
  security_scan: true
  api_validation: true

memory:
  type: "vector"
  storage: "chroma"

excludes:
  - "node_modules"
  - "venv"
  - ".venv"
  - "__pycache__"
  - "*.pyc"
  - "dist"
  - "build"
