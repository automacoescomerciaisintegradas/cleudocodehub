# Cleudocode Core Configuration
# Template: cli
# Focado em desenvolvimento de ferramentas CLI

version: "1.0.0"
name: "cleudocode-core-cli"

settings:
  language: "pt-BR"
  default_agent: "cli-dev"
  verbose: false
  log_mode: "console"

llms:
  models:
    - name: "qwen3:4b"
      backend: "ollama"
      hostname: "http://localhost:11434"
      enabled: true

agents:
  enabled:
    - "cli-dev"
    - "shell-scripting"
    - "testing"
  default: "cli-dev"
  max_workers: 4

rules:
  javascript:
    indentation: "space"
    indent_size: 2
    quote_style: "single"
    semicolons: false
  
  python:
    indentation: "space"
    indent_size: 4
    type_hints: true
  
  naming:
    files: "kebab-case"
    functions: "camelCase"
  
  commits:
    style: "conventional"

paths:
  rules: ".agents/rules"
  agents: ".agents/agents"
  templates: ".agents/templates"

features:
  code_generation: true
  auto_documentation: true
  testing: true
  shell_integration: true

memory:
  type: "vector"
  storage: "chroma"

excludes:
  - "node_modules"
  - "venv"
  - ".venv"
  - "dist"
  - "build"
