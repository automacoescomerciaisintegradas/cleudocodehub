{
  "name": "@cleudocode/cleudocode-core",
  "version": "1.0.0",
  "description": "Cleudocode Core - AI Orchestration Framework para desenvolvimento com agentes AI",
  "author": "Cleudocode Team",
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "orchestrator",
    "cleudocode",
    "cli",
    "automation",
    "development",
    "llm"
  ],
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "cleudocode": "./bin/cleudocode.js",
    "cleudocode-core": "./bin/cleudocode.js",
    "ccore": "./bin/cleudocode.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    ".cleudocode-core",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "start": "node bin/cleudocode.js",
    "dev": "node --watch bin/cleudocode.js",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.3.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "semver": "^7.7.1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cleudocode/cleudocode-core.git"
  },
  "bugs": {
    "url": "https://github.com/cleudocode/cleudocode-core/issues"
  },
  "homepage": "https://github.com/cleudocode/cleudocode-core#readme",
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yaml,yml}": [
      "prettier --write"
    ]
  }
}
