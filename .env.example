# =============================================================================
# Cleudocode Hub - Environment Variables Example
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys (LLMs)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace
HF_AUTH_TOKEN=hf_...
HF_CACHE_DIR=~/.cache/huggingface

# -----------------------------------------------------------------------------
# Vector Database (Opcional)
# -----------------------------------------------------------------------------
# Qdrant (se usar ao invés de Chroma)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Servidor (Opcional)
# -----------------------------------------------------------------------------
CLEUDOCODE_HOST=localhost
CLEUDOCODE_PORT=8000

# -----------------------------------------------------------------------------
# Configurações Gerais
# -----------------------------------------------------------------------------
NODE_ENV=development
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Ollama (Configurações Locais)
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
