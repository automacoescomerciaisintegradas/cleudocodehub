# =============================================================================
# .env.example — cleudocode-hub
# Copie para .env e preencha com seus valores reais
# NUNCA commite o .env no git!
# =============================================================================

# Provider LLM padrão
DEFAULT_PROVIDER=ollama
LLM_FALLBACK_SEQUENCE=ollama,groq,gemini

# Ollama (local ou remoto)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=GandalfBaum/llama3.1-claude3.7:latest

# Groq (opcional)
GROQ_API_KEY=gsk_...

# Google Gemini (opcional)
GOOGLE_API_KEY=AIza...

# OpenAI (opcional)
OPENAI_API_KEY=sk-...

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Obtenha o token via @BotFather no Telegram: /newbot ou /token
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI

# ── Traefik / Domínio ─────────────────────────────────────────────────────────
DOMAIN=cleudocode.com.br
ACME_EMAIL=seu@email.com
